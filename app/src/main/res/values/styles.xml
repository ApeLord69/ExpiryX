<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Example widget style -->
    <style name="Widget.ExpiryX.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.ExpiryX.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:minHeight">56dp</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.ExpiryX.BottomNav.ActiveIndicator</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">?attr/colorPrimaryContainer</item>
        <item name="itemPaddingTop">2dp</item>
        <item name="itemPaddingBottom">4dp</item>
    </style>

    <style name="Widget.ExpiryX.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
        <item name="marginHorizontal">8dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.ExpiryX.BottomNavIndicator</item>
    </style>

    <style name="ShapeAppearance.ExpiryX.BottomNavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.ExpiryX.EditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="SettingsHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="SettingsCard" parent="Widget.Material3.CardView.Outlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/settings_card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SettingsIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">?attr/colorOnPrimary</item>
    </style>

    <style name="SettingsIconNoTint">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="SpecialSettingsCard" parent="SettingsCard">
        <item name="cardBackgroundColor">@color/special_card_bg</item>
        <item name="strokeColor">@color/special_card_stroke</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="SpecialSettingsTitle" parent="SettingsTitle">
        <item name="android:textColor">@color/special_card_text</item>
    </style>

    <style name="SpecialSettingsSubtitle" parent="SettingsSubtitle">
        <item name="android:textColor">@color/special_card_text</item>
        <item name="android:alpha">0.7</item>
    </style>

    <style name="SettingsIconContainer">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:background">@drawable/settings_icon_background</item>
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="SettingsTextLayout">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SettingsSubtitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>

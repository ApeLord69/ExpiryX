<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ExpiryX.Base" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_200</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurfaceVariant">@color/dark_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/dark_on_surface_variant</item>
        <item name="colorOnBackground">@color/dark_on_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.ExpiryX.BottomSheetDialog</item>
        <item name="alertDialogTheme">@style/Theme.Material3.DayNight.Dialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="colorAccent">?attr/colorPrimary</item>
        <item name="colorControlActivated">?attr/colorPrimary</item>
        <item name="colorControlHighlight">?attr/colorPrimaryContainer</item>
        <item name="expiryTextSafe">@color/expiry_text_safe_dark</item>
        <item name="expiryTextUrgent">@color/expiry_text_urgent_dark</item>
        <item name="expiryTextExpired">@color/expiry_text_expired_dark</item>
        <item name="expiryTextUnknown">@color/expiry_text_unknown_dark</item>
    </style>

    <style name="ThemeOverlay.ExpiryX.BottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="colorPrimary">?attr/colorPrimary</item>
        <item name="colorOnPrimary">?attr/colorOnPrimary</item>
        <item name="colorPrimaryContainer">?attr/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">?attr/colorOnPrimaryContainer</item>
        <item name="colorSecondary">?attr/colorSecondary</item>
        <item name="colorOnSecondary">?attr/colorOnSecondary</item>
    </style>

    <style name="Theme.ExpiryX" parent="Theme.ExpiryX.Aqua" />

    <style name="Theme.ExpiryX.Aqua" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">@color/teal_200</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">#1A3A36</item>
        <item name="colorOnPrimaryContainer">@color/teal_200</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">#1A3A36</item>
        <item name="colorOnSecondaryContainer">@color/teal_200</item>
    </style>

    <style name="Theme.ExpiryX.Coral" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">@color/coral_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#3E2723</item>
        <item name="colorOnPrimaryContainer">#FFAB91</item>
        <item name="colorSecondary">@color/coral_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">#3E2723</item>
        <item name="colorOnSecondaryContainer">#FFAB91</item>
    </style>

    <style name="Theme.ExpiryX.Sky" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">@color/sky_primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">#0D3044</item>
        <item name="colorOnPrimaryContainer">#81D4FA</item>
        <item name="colorSecondary">@color/sky_primary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">#0D3044</item>
        <item name="colorOnSecondaryContainer">#81D4FA</item>
    </style>

    <style name="Theme.ExpiryX.Violet" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">@color/violet_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#311B33</item>
        <item name="colorOnPrimaryContainer">#CE93D8</item>
        <item name="colorSecondary">@color/violet_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">#311B33</item>
        <item name="colorOnSecondaryContainer">#CE93D8</item>
    </style>

    <style name="Theme.ExpiryX.Forest" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">#81C784</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">#1B3320</item>
        <item name="colorOnPrimaryContainer">#81C784</item>
        <item name="colorSecondary">#81C784</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">#1B3320</item>
        <item name="colorOnSecondaryContainer">#81C784</item>
    </style>

    <style name="Theme.ExpiryX.Rose" parent="Theme.ExpiryX.Base">
        <item name="colorPrimary">#F06292</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">#331B25</item>
        <item name="colorOnPrimaryContainer">#F06292</item>
        <item name="colorSecondary">#F06292</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">#331B25</item>
        <item name="colorOnSecondaryContainer">#F06292</item>
    </style>

    <style name="Theme.ExpiryX.Camera" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="ThemeOverlay.ExpiryX.NumberPicker" parent="ThemeOverlay.Material3.Dark">
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="colorControlNormal">@android:color/transparent</item>
    </style>

    <style name="ThemeOverlay.ExpiryX.HighContrast" parent="">
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="expiryTextSafe">@color/white</item>
        <item name="expiryTextUrgent">@color/white</item>
        <item name="expiryTextExpired">@color/white</item>
    </style>
</resources>

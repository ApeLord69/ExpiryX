<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:background="@drawable/header_background"
        android:elevation="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/titleSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorOnBackground"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/nav_separator"
        android:layout_below="@id/topBar" />

    <!-- Scrollable settings content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <!-- Preferences Section -->
            <TextView
                style="@style/SettingsHeader"
                android:paddingTop="8dp"
                android:text="ACCOUNT" />

            <!-- Google Account Info -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/account_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/account_icon_container"
                        style="@style/SettingsIconContainer">

                        <ImageView
                            android:id="@+id/user_profile_image"
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_google_logo"
                            app:tint="@null"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/account_icon_container"
                        android:layout_toStartOf="@+id/btn_account_action">

                        <TextView
                            android:id="@+id/user_name_text"
                            style="@style/SettingsTitle"
                            android:text="Not signed in" />
                        <TextView
                            android:id="@+id/user_email_text"
                            style="@style/SettingsSubtitle"
                            android:text="Sign in to sync your data" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_account_action"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Sign In"
                        android:textColor="?attr/colorPrimary"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cloud Sync Switch -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sync_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/sync_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_sync"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/sync_icon_container"
                        android:layout_toStartOf="@+id/sync_switch">

                        <TextView style="@style/SettingsTitle" android:text="Cloud Sync" />
                        <TextView style="@style/SettingsSubtitle" android:text="Keep your data in sync across devices" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sync_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preferences Section -->
            <TextView
                style="@style/SettingsHeader"
                android:paddingTop="8dp"
                android:text="PREFERENCES" />

            <!-- Notifications -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/notifications_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/notifications_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/notifications_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Notifications" />
                        <TextView style="@style/SettingsSubtitle" android:text="Manage reminder time &amp; intervals" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Accent theme -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/accent_theme_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/accent_theme_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_palette"
                            app:tint="?attr/colorOnPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/accent_theme_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/accent_color" />
                        <TextView
                            android:id="@+id/accentThemeSubtitle"
                            style="@style/SettingsSubtitle"
                            android:text="@string/accent_color_subtitle" />

                        <LinearLayout
                            android:id="@+id/accentSwatchPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dark Mode -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dark_mode_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/dark_mode_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_dark_mode"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/dark_mode_icon_container"
                        android:layout_toStartOf="@+id/dark_mode_switch">

                        <TextView style="@style/SettingsTitle" android:text="Dark Mode" />
                        <TextView style="@style/SettingsSubtitle" android:text="Switch between light &amp; dark" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/dark_mode_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Data & Storage Section -->
            <TextView
                style="@style/SettingsHeader"
                android:paddingTop="8dp"
                android:text="DATA &amp; STORAGE" />

            <!-- Export Data -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/export_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/export_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_export"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/export_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Export Data" />
                        <TextView style="@style/SettingsSubtitle" android:text="Download your stored data to CSV" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Import Data -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/import_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/import_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_sync"
                            app:tint="@color/white"
                            android:rotation="180"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/import_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Import Data" />
                        <TextView style="@style/SettingsSubtitle" android:text="Restore data from a CSV file" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>



            <!-- Delete All Data -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/delete_data_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/delete_data_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="?attr/colorPrimary">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_delete"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/delete_data_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Reset Local Data" />
                        <TextView style="@style/SettingsSubtitle" android:text="Wipe offline database &amp; caches" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Section (moved to bottom) -->
            <TextView
                style="@style/SettingsHeader"
                android:paddingTop="8dp"
                android:text="ABOUT"
                android:textColor="@color/gold" />

            <!-- Donate -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/donate_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                app:cardBackgroundColor="@color/light_gold"
                app:strokeColor="@color/gold"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/donate_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="@color/gold">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_fav_filled"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/donate_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Donate" />
                        <TextView style="@style/SettingsSubtitle" android:text="Support development of ExpiryX" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rate this App -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rate_card"
                style="@style/SettingsCard"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/light_gold"
                app:strokeColor="@color/gold"
                app:strokeWidth="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/rate_icon_container"
                        style="@style/SettingsIconContainer"
                        android:backgroundTint="@color/gold">

                        <ImageView
                            style="@style/SettingsIcon"
                            android:src="@drawable/ic_star"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingsTextLayout"
                        android:layout_toEndOf="@id/rate_icon_container"
                        android:layout_alignParentEnd="true">

                        <TextView style="@style/SettingsTitle" android:text="Rate this App" />
                        <TextView style="@style/SettingsSubtitle" android:text="Leave a review on Google Play" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App Version -->
            <TextView
                android:id="@+id/appVersionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="8dp"
                android:text="Version 1.0"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNav"
        layout="@layout/include_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />
</RelativeLayout>
